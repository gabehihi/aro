# aro 환경 변수 템플릿
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요

# Database
DATABASE_URL=sqlite+aiosqlite:///./aro.db

# Security - JWT 서명 키 (openssl rand -hex 32 으로 생성)
SECRET_KEY=your-secret-key-here

# Security - AES-256 암호화 키 (python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())" 로 생성)
ENCRYPTION_KEY=your-encryption-key-here

# 초기 관리자 비밀번호 (미설정 시 랜덤 생성 후 콘솔 출력)
INITIAL_ADMIN_PASSWORD=

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama (오프라인 fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b

# Debug
DEBUG=true
